---
import Layout from '../layouts/Layout.astro';
import config from '../data/config.json';
---

<Layout title="Registration">
	<section class="page-header">
        <div class="container">
            <h1>Registration & Participation</h1>
        </div>
    </section>

    <section class="content">
        <div class="container">
            <div class="alert-box">
                <strong>Status:</strong> Registration opens February 25th, 2026.
            </div>

            <div class="grid-section">
                <div class="reg-fees">
           <div class="reg-fees">
    <h2>Conference Fees</h2>

    <table class="fees-table">
        <tr>
            <td>Professional Ticket</td>
            <td class="price">£350</td>
        </tr>
        <tr>
            <td>Professional Ticket (Early Bird)</td>
            <td class="price">£300</td>
        </tr>
        <tr>
            <td>Individual Ticket</td>
            <td class="price">£250</td>
        </tr>
        <tr>
            <td>Individual Ticket (Early Bird)</td>
            <td class="price">£200</td>
        </tr>
            <tr>
            <td>Student Ticket</td>
            <td class="price">£150</td>
        </tr>
    </table>

    <p><strong>Early Bird discount expires end of April.</strong></p>
    <br>

    <h>Celebratory Dinner</h3>
    <p>
        Friday 18th September, 7:00pm – 11:00pm<br />
        <strong>£55</strong> (includes a glass of wine and a buffet)
        <br>
    </p>

    <p>
        We welcome applications for discounts for special circumstances 
        </p>
        <p>please contact 
        <a href="mailto:mph_2026_registrations@metaphorum.org">
            mph_2026_registrations@metaphorum.org
        </a>
    </p>

    <p>
        <a href="https://buytickets.at/metaphorum1/2078896/share/f7b9ba988ee9ffbc6679b34a0d283421" target="_blank">
    <h3>Make a Payment</h3>
        </a>
    </p>
</div> 
          

        
            </div>
        </div>
    </section>
</Layout>

<style>
    .page-header {
        background: var(--color-primary);
        color: white;
        padding: 3rem 0;
    }

    .alert-box {
        background: #e3f2fd;
        color: #0d47a1;
        padding: 1rem;
        border-radius: 4px;
        margin-bottom: 2rem;
        border-left: 4px solid #0d47a1;
    }

    .grid-section {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
    }

    .fees-table {
        width: 100%;
        margin-bottom: 2rem;
        border-collapse: collapse;
    }

    .fees-table td {
        padding: 1rem 0;
        border-bottom: 1px solid var(--color-border);
    }

    .fees-table .price {
        text-align: right;
        font-weight: 600;
    }

    .submission-card {
        background: var(--color-background-alt);
        padding: 2rem;
        border-radius: 8px;
        border: 1px solid var(--color-border);
    }

    .submission-card ul {
        margin: 1rem 0;
        padding-left: 1.5rem;
    }

    .action-area {
        margin-top: 1.5rem;
        text-align: center;
        background: white;
        padding: 1.5rem;
        border-radius: 4px;
    }

    .email-btn {
        display: inline-block;
        background: var(--color-primary);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 4px;
        text-decoration: none;
        font-weight: 600;
        margin: 0.5rem 0;
    }

    .small-note {
        font-size: 0.85rem;
        color: #666;
    }

    @media (max-width: 768px) {
        .grid-section {
            grid-template-columns: 1fr;
        }
    }
</style>
